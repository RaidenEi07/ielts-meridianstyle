# Copy to .env and adjust. Used by docker-compose and (optionally) the backend.

# --- Database ---
DB_NAME=meridian
DB_USER=meridian
DB_PASSWORD=meridian
DB_PORT=5432

# --- Backend (Spring Boot) ---
# DB_URL=jdbc:postgresql://localhost:5432/meridian
# SERVER_PORT=8090
# JWT secret must be at least 32 chars (256-bit) for HS256.
JWT_SECRET=change-me-in-production-this-is-a-dev-only-secret-key-0123456789
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
CORS_ALLOWED_ORIGINS=http://localhost:3100

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8090

# --- docker-compose.prod.yml only ---
# ADMIN_USERNAME dùng để đăng nhập; ADMIN_EMAIL chỉ để liên hệ/thông báo.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@meridian.edu.vn
ADMIN_PASSWORD=change-me-strong-password
BACKEND_PORT=8090
FRONTEND_PORT=3100
